# =============================================================================
# Server (required for running the app)
# =============================================================================

# Encryption key for secrets stored in the database (AES-256, base64-encoded)
# Generate with: openssl rand -base64 32
BUDGETBUDDY_ENCRYPTION_KEY=

# Database directory (optional, defaults to ~/my_apps/budgetbuddy-dev/)
# DATA_DIR=

# =============================================================================
# Deployment (only needed for Docker + Tailscale)
# =============================================================================

# Tailscale auth key - get from https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-XXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# Scripts & Integration Tests (not needed for the server)
#
# The server reads these credentials from the database (entered via UI).
# These env vars are only used by scripts in scripts/ and integration tests.
# =============================================================================

# YNAB API - get from https://app.youneedabudget.com/settings/developer
# YNAB_TOKEN=your-personal-access-token-here

# Comdirect API - OAuth credentials
# COMDIRECT_CLIENT_ID=your-client-id
# COMDIRECT_CLIENT_SECRET=your-client-secret
# COMDIRECT_USERNAME=your-username
# COMDIRECT_PASSWORD=your-password
# COMDIRECT_ACCOUNT_ID=your-account-id

# Set to 'true' to enable real API integration tests
# WARNING: This will make actual API calls (including Push-TAN for Comdirect)
# RUN_INTEGRATION_TESTS=true
